---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import { t } from '../../i18n/translations';

const locale = 'en';
const i18n = t(locale);
const base = import.meta.env.BASE_URL;
const prefix = `${base}/en`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Morgan Sebode — Counselling & Psychotherapy',
  description: i18n.site.description,
  url: `https://jean-chouky.github.io${base}/en/`,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Vannes',
    addressRegion: 'Brittany',
    addressCountry: 'FR',
  },
  priceRange: '$$',
  openingHours: 'Mo-Fr 09:00-18:00',
  areaServed: [
    { '@type': 'City', name: 'Vannes' },
    { '@type': 'AdministrativeArea', name: 'Brittany' },
    { '@type': 'Country', name: 'United Kingdom' },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Counselling services',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Individual therapy' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Family therapy' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Couple therapy' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Online counselling' } },
    ],
  },
};
---

<BaseLayout locale={locale} schema={schema}>
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-sage-50 via-warm-50 to-sage-100 py-20 sm:py-28 lg:py-36">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-serif font-bold text-navy-900 leading-tight">
          {i18n.hero.title}
        </h1>
        <p class="mt-4 sm:mt-6 text-lg sm:text-xl text-navy-600 max-w-2xl">
          {i18n.hero.subtitle}
        </p>
        <div class="mt-8 sm:mt-10 flex flex-col sm:flex-row gap-4">
          <a
            href={`${prefix}/booking/`}
            class="inline-flex items-center justify-center px-6 py-3 bg-sage-600 text-white font-medium rounded-lg hover:bg-sage-700 transition-colors focus:outline-none focus:ring-2 focus:ring-sage-500 focus:ring-offset-2"
          >
            {i18n.hero.cta}
          </a>
          <a
            href={`${prefix}/about/`}
            class="inline-flex items-center justify-center px-6 py-3 border-2 border-sage-300 text-sage-700 font-medium rounded-lg hover:bg-sage-50 transition-colors focus:outline-none focus:ring-2 focus:ring-sage-500 focus:ring-offset-2"
          >
            {i18n.hero.ctaSecondary}
          </a>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 right-0 w-1/3 h-full opacity-10 pointer-events-none" aria-hidden="true">
      <svg viewBox="0 0 200 200" class="w-full h-full">
        <circle cx="150" cy="100" r="80" fill="#7a8b65" />
        <circle cx="100" cy="150" r="60" fill="#7a8b65" />
      </svg>
    </div>
  </section>

  <Section>
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-serif font-bold text-navy-900">{i18n.home.welcomeTitle}</h2>
      <p class="mt-6 text-lg text-navy-600 leading-relaxed">{i18n.home.welcomeText}</p>
    </div>
  </Section>

  <Section bg="sage">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-serif font-bold text-navy-900">{i18n.home.approachTitle}</h2>
      <p class="mt-6 text-lg text-navy-700 leading-relaxed">{i18n.home.approachText}</p>
    </div>
  </Section>

  <Section>
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-serif font-bold text-navy-900">{i18n.home.servicesTitle}</h2>
      <p class="mt-4 text-lg text-navy-600 max-w-2xl mx-auto">{i18n.home.servicesText}</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { icon: '🧑', ...i18n.services.individual },
        { icon: '👧', ...i18n.services.children },
        { icon: '🧩', ...i18n.services.autism },
        { icon: '👨‍👩‍👧‍👦', ...i18n.services.family },
        { icon: '💑', ...i18n.services.couple },
        { icon: '💻', ...i18n.services.online },
      ].map(service => (
        <a href={`${prefix}/services/`} class="group block p-6 bg-white rounded-xl shadow-sm hover:shadow-md border border-sage-100 transition-all">
          <div class="text-3xl mb-3" aria-hidden="true">{service.icon}</div>
          <h3 class="text-lg font-serif font-semibold text-navy-800 group-hover:text-sage-600 transition-colors">{service.title}</h3>
          <p class="mt-2 text-sm text-navy-600 line-clamp-3">{service.text}</p>
        </a>
      ))}
    </div>
  </Section>

  <Section bg="white">
    <div class="text-center mb-10">
      <h2 class="text-3xl sm:text-4xl font-serif font-bold text-navy-900">{i18n.home.issuesTitle}</h2>
    </div>
    <div class="max-w-3xl mx-auto grid grid-cols-2 sm:grid-cols-3 gap-3">
      {i18n.home.issues.map(issue => (
        <div class="flex items-center gap-2 px-4 py-3 bg-sage-50 rounded-lg text-sm text-navy-700">
          <svg class="w-4 h-4 text-sage-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          {issue}
        </div>
      ))}
    </div>
  </Section>

  <Section bg="sage">
    <div class="text-center">
      <h2 class="text-3xl sm:text-4xl font-serif font-bold text-navy-900">Ready to start?</h2>
      <p class="mt-4 text-lg text-navy-700 max-w-xl mx-auto">
        The first step is often the hardest. I'm here to welcome you.
      </p>
      <a
        href={`${prefix}/booking/`}
        class="mt-8 inline-flex items-center justify-center px-8 py-3.5 bg-sage-600 text-white font-medium rounded-lg hover:bg-sage-700 transition-colors text-lg focus:outline-none focus:ring-2 focus:ring-sage-500 focus:ring-offset-2"
      >
        {i18n.hero.cta}
      </a>
    </div>
  </Section>
</BaseLayout>
