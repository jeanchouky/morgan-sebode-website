---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import { t } from '../../i18n/translations';

const locale = 'en';
const i18n = t(locale);
const base = import.meta.env.BASE_URL;
const prefix = `${base}/en`;
---

<BaseLayout
  locale={locale}
  title={`${i18n.services.pageTitle} — Morgan Sebode`}
  description={i18n.services.metaDescription}
>
  <section class="bg-gradient-to-br from-sage-50 to-warm-50 py-16 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl sm:text-5xl font-serif font-bold text-navy-900">{i18n.services.pageTitle}</h1>
      <p class="mt-4 text-lg text-navy-600 max-w-2xl">{i18n.services.intro}</p>
    </div>
  </section>

  {[
    { bg: 'default' as const, ...i18n.services.individual },
    { bg: 'sage' as const, ...i18n.services.children },
    { bg: 'default' as const, ...i18n.services.autism },
    { bg: 'sage' as const, ...i18n.services.family },
    { bg: 'default' as const, ...i18n.services.couple },
    { bg: 'sage' as const, ...i18n.services.online },
  ].map(service => (
    <Section bg={service.bg}>
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl sm:text-3xl font-serif font-bold text-navy-900 mb-6">{service.title}</h2>
        <p class="text-lg text-navy-700 leading-relaxed">{service.text}</p>
      </div>
    </Section>
  ))}

  <Section bg="white">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-serif font-bold text-navy-900 mb-8">{i18n.services.sessionInfo.title}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          { icon: '🕐', text: i18n.services.sessionInfo.duration },
          { icon: '📍', text: i18n.services.sessionInfo.location },
          { icon: '🌐', text: i18n.services.sessionInfo.remote },
          { icon: '🗣️', text: i18n.services.sessionInfo.languages },
        ].map(item => (
          <div class="flex items-center gap-3 p-4 bg-sage-50 rounded-lg">
            <span class="text-2xl" aria-hidden="true">{item.icon}</span>
            <span class="text-navy-700">{item.text}</span>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <Section bg="sage">
    <div class="text-center">
      <a
        href={`${prefix}/booking/`}
        class="inline-flex items-center justify-center px-8 py-3.5 bg-sage-600 text-white font-medium rounded-lg hover:bg-sage-700 transition-colors text-lg focus:outline-none focus:ring-2 focus:ring-sage-500 focus:ring-offset-2"
      >
        {i18n.hero.cta}
      </a>
    </div>
  </Section>
</BaseLayout>
