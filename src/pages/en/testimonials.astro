---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import { t } from '../../i18n/translations';

const locale = 'en';
const i18n = t(locale);
const base = import.meta.env.BASE_URL;
const prefix = `${base}/en`;
---

<BaseLayout
  locale={locale}
  title={`${i18n.testimonials.pageTitle} — Morgan Sebode`}
  description={i18n.testimonials.metaDescription}
>
  <section class="bg-gradient-to-br from-sage-50 to-warm-50 py-16 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl sm:text-5xl font-serif font-bold text-navy-900">{i18n.testimonials.pageTitle}</h1>
      <p class="mt-4 text-lg text-navy-600 max-w-2xl">{i18n.testimonials.intro}</p>
    </div>
  </section>

  <Section>
    <div class="max-w-4xl mx-auto space-y-8">
      {i18n.testimonials.items.map((item, i) => (
        <blockquote class:list={['p-8 rounded-xl', i % 2 === 0 ? 'bg-sage-50' : 'bg-warm-50']}>
          <svg class="w-8 h-8 text-sage-300 mb-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z" />
          </svg>
          <p class="text-lg text-navy-700 leading-relaxed italic">{item.text}</p>
          <footer class="mt-4 text-sage-600 font-medium">— {item.author}</footer>
        </blockquote>
      ))}
    </div>
  </Section>

  <Section bg="sage">
    <div class="text-center">
      <a
        href={`${prefix}/booking/`}
        class="inline-flex items-center justify-center px-8 py-3.5 bg-sage-600 text-white font-medium rounded-lg hover:bg-sage-700 transition-colors text-lg focus:outline-none focus:ring-2 focus:ring-sage-500 focus:ring-offset-2"
      >
        {i18n.hero.cta}
      </a>
    </div>
  </Section>
</BaseLayout>
